def count_acts(regimes, view_point, char):
    Points = pd.DataFrame()
    res = {}
    for regime in regimes:
        for relay in ['AB', 'BC', 'CA']:
            Points['real'] = Z[regime][view_point][relay].map(lambda x: x.real)
            Points['imag'] = Z[regime][view_point][relay].map(lambda x: x.imag) 
            Points['coord'] = Points.apply(lambda x: (x['real'], x['imag']) , axis=1)
            Points['act_'+relay] = Points['coord'].map(lambda x: char.contains(Point(x)))
        s = Points[['act_AB', 'act_BC', 'act_CA']].any(axis=1).sum()
        res[regime] = s
    return res
