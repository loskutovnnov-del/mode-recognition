def get_Z(U, I):
    Z = pd.DataFrame()
    UI = pd.concat([U, I], axis=1)
    UI.columns = ['Ua', 'Ub', 'Uc', 'Ia', 'Ib', 'Ic']
    Z['AB'] = UI.apply(lambda x: (x['Ua'] - x['Ub']) / (x['Ia'] - x['Ib']), axis=1)
    Z['BC'] = UI.apply(lambda x: (x['Ub'] - x['Uc']) / (x['Ib'] - x['Ic']), axis=1)
    Z['CA'] = UI.apply(lambda x: (x['Uc'] - x['Ua']) / (x['Ic'] - x['Ia']), axis=1)
    return Z
​
def get_S(U, I):
    S = pd.DataFrame()
    UI = pd.concat([U, I], axis=1)
    UI.columns = ['Ua', 'Ub', 'Uc', 'Ia', 'Ib', 'Ic']
    for phase in ['A', 'B', 'C']:
        S[phase] = UI.apply(
            lambda x: x['U' + phase.lower()] * np.conj(x['I' + phase.lower()]), 
            axis=1
        )
    return S
​
def get_RMS(U, I):
    RMS = pd.DataFrame()
    UI = pd.concat([U, I], axis=1)
    UI.columns = ['Ua', 'Ub', 'Uc', 'Ia', 'Ib', 'Ic']
    return UI.applymap(abs)
​
def get_sequences(signal):
    product = np.dot(signal, np.linalg.inv(s.T))
    return pd.DataFrame(product, columns = ['Positive', 'Negative', 'Zero'], index=signal.index)
