def plot_hist(alpha, beta, alpha_bins, beta_bins, alpha_first=True, xlim=None, threshold=None):
    n_alpha = alpha.shape[0]
    n_beta = beta.shape[0]
    n = n_alpha + n_beta
    
    alpha_dict = {'color': 'r', 'values': alpha, 'bins': alpha_bins}
    beta_dict = {'color': 'b', 'values': beta, 'bins': beta_bins}
    
    seq = [beta_dict, alpha_dict] if alpha_first else [alpha_dict, beta_dict]
​
    n = sum([data['values'].shape[0] for data in seq])
    
    for data in seq:
        hist_values, bin_edges = np.histogram(data['values'], bins=data['bins'])
        norm = n * (bin_edges[1] - bin_edges[0])
        plt.bar(x=bin_edges[:-1], height=hist_values / norm, width=np.diff(bin_edges), align='edge',
                color=data['color'], edgecolor='k', alpha=0.7)
    if xlim:
        plt.xlim(*xlim)
    if threshold:
        plt.axvline(threshold, 0, 1, color = 'k')
    plt.grid()
    plt.show()
